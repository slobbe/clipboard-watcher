{
    "name": "clipboard-watcher",
    "private": true,
    "type": "module",
    "scripts": {
        "lint": "eslint src",
        "format": "prettier --write \"src/**/*.js\" \".github/workflows/*.yml\" \"eslint.config.js\" \"package.json\" \".prettierrc.json\"",
        "format:check": "prettier --check \"src/**/*.js\" \".github/workflows/*.yml\" \"eslint.config.js\" \"package.json\" \".prettierrc.json\""
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.7.0",
        "prettier": "^3.9.5"
    }
}
